# Frontend build-time env vars (CRA / react-scripts)
# Copy to: frontend/.env before building

# API base URL (required in production)
REACT_APP_API_BASE_URL=https://api-ashrafessa.mela-media.co.il/api

# App branding (used in Terms page, etc.)
REACT_APP_APP_NAME=AshrafEssa
REACT_APP_NOREPLY_EMAIL=noreply@ashrafessa.mela-media.co.il

# Default language (ar for Arabic)
REACT_APP_DEFAULT_LANG=ar
